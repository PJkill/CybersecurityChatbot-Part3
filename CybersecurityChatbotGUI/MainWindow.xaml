<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbotGUI"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot - POE" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII art header -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Margin="0,0,0,10" Padding="8">
            <TextBlock x:Name="AsciiArtBlock" FontFamily="Consolas" FontSize="12" 
                       Text="Loading ASCII art..." Foreground="#1ABC9C" 
                       HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <!-- Main content with tabs -->
        <TabControl Grid.Row="1" Margin="0,0,0,10">
            <!-- Tab 1: Chat -->
            <TabItem Header="💬 Chat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ConversationList" Grid.Row="0" Margin="0,0,0,10" 
                             Background="White" BorderBrush="#BDC3C7" 
                             FontFamily="Segoe UI" FontSize="14">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="UserInputBox" Height="35" Width="650" 
                                 Margin="0,0,10,0" VerticalContentAlignment="Center"
                                 FontSize="14" BorderBrush="#7F8C8D" BorderThickness="1"/>
                        <Button x:Name="SendButton" Content="Send" Width="80" Height="35"
                                Background="#3498DB" Foreground="White" FontWeight="Bold"
                                Click="SendButton_Click" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Task Assistant -->
            <TabItem Header="📋 Task Assistant">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Add New Task" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Title:" Width="60" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtTaskTitle" Width="200" Margin="0,0,10,0"/>
                        <TextBlock Text="Reminder (YYYY-MM-DD):" Width="150" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtReminder" Width="120"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Description:" Width="60" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtTaskDescription" Width="400" Margin="0,0,10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add Task" Click="AddTask_Click" Width="100" Margin="0,0,10,0"
                                Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Refresh" Click="RefreshTasks_Click" Width="100" Margin="0,0,10,0"
                                Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="4" x:Name="dgTasks" AutoGenerateColumns="False" 
                              Margin="0,10,0,0" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="150"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                            <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsCompleted}" Width="60"/>
                            <DataGridTemplateColumn Header="Actions" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✓" Click="CompleteTask_Click" Tag="{Binding Id}" 
                                                    Background="#27AE60" Foreground="White" Width="30" Margin="0,0,5,0"/>
                                            <Button Content="✗" Click="DeleteTask_Click" Tag="{Binding Id}" 
                                                    Background="#E74C3C" Foreground="White" Width="30"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 3: Quiz -->
            <TabItem Header="🎯 Cybersecurity Quiz">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Start Quiz" Click="StartQuiz_Click" Width="120" Height="35"
                                Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <TextBlock x:Name="txtQuizProgress" Text="Questions: 0/0" Margin="20,10,0,0" FontSize="14"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" x:Name="txtQuizQuestion" Text="Click 'Start Quiz' to begin!" 
                               FontSize="16" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <ComboBox Grid.Row="2" x:Name="cmbQuizOptions" Height="30" Margin="0,0,0,10" FontSize="14"/>

                    <Button Grid.Row="3" Content="Submit Answer" Click="SubmitAnswer_Click" Width="120" Height="30"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                    <TextBlock Grid.Row="4" x:Name="txtQuizResult" Text="" FontSize="14" 
                               TextWrapping="Wrap" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <!-- Tab 4: Activity Log -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Refresh Log" Click="RefreshLog_Click" Width="120" Margin="0,0,0,10"
                            Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                    <ListBox Grid.Row="1" x:Name="lstActivityLog" FontSize="14" Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>