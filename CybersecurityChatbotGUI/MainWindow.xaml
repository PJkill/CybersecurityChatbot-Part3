<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbotGUI"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot" Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII art header -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Margin="0,0,0,10" Padding="8">
            <TextBlock x:Name="AsciiArtBlock" FontFamily="Consolas" FontSize="12" 
                       Text="Loading ASCII art..." Foreground="#1ABC9C" 
                       HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <!-- Conversation history -->
        <ListBox x:Name="ConversationList" Grid.Row="1" Margin="0,0,0,10" 
                 Background="White" BorderBrush="#BDC3C7" 
                 FontFamily="Segoe UI" FontSize="14">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input area -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
            <TextBox x:Name="UserInputBox" Height="35" Width="580" 
                     Margin="0,0,10,0" VerticalContentAlignment="Center"
                     FontSize="14" BorderBrush="#7F8C8D" BorderThickness="1"/>
            <Button x:Name="SendButton" Content="Send" Width="80" Height="35"
                    Background="#3498DB" Foreground="White" FontWeight="Bold"
                    Click="SendButton_Click" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>